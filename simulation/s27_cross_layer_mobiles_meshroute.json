  }
 },
 "commands": [
  {
   "_c": "PHASE B — plaintext-first, INTRO auto-attaches M1's pubkey (D1: no sealed frame from dst yet). Same-layer by hash.",
   "at_ms": 220000,
   "node": "M1",
   "command": "send_hash 3a3e77a3 hello-m2"
  },
  {
   "_c": "cross-layer (leaf 7) via the S1 layer-qualified delegated send",
   "at_ms": 240000,
   "node": "M1",
   "command": "send_layer 7 3166780613 hello-m3"
  },
  {
   "at_ms": 260000,
   "node": "M1",
   "command": "send_layer 7 1163906905 hello-m4"
  },
  {
   "_c": "replies — INTRO attaches each replier's key back to M1 (mutual keys, zero floods)",
   "at_ms": 300000,
   "node": "M2",
   "command": "send_hash 2716efcd re-m2"
  },
  {
   "at_ms": 320000,
   "node": "M3",
   "command": "send_layer 4 655814605 re-m3"
  },
  {
   "at_ms": 340000,
   "node": "M4",
   "command": "send_layer 4 655814605 re-m4"
  },
  {
   "_c": "PHASE C — encrypted (both sides hold both keys from phase B). Same-layer sealed.",
   "at_ms": 420000,
   "node": "M1",
   "command": "send_hashx 3a3e77a3 sealed-to-m2"
  },
  {
   "_c": "CROSS-LAYER sealed (spec S4: XL seal lift + hash-keyed ack)",
   "at_ms": 440000,
   "node": "M1",
   "command": "send_layerx 7 3166780613 sealed-to-m3"
  },
  {
   "at_ms": 460000,
   "node": "M1",
   "command": "send_layerx 7 1163906905 sealed-to-m4"
  },
  {
   "_c": "encrypted the OTHER way too (proves the mutual half of INTRO)",
   "at_ms": 500000,
   "node": "M3",
   "command": "send_layerx 4 655814605 sealed-re-m3"
  },
  {
   "_c": "PHASE E — after the phase-D re-homes (S4 dies 600k, T1 620k, T4 640k; spares up at 560k): senders' cached homes are STALE-DEAD -> re-resolve; the NEW homes must hold the re-pushed keys (spec S3)",
   "at_ms": 950000,
   "node": "M1",
   "command": "send_hashx 3a3e77a3 post-m2"
  },
  {
   "at_ms": 980000,
   "node": "M1",
   "command": "send_layerx 7 3166780613 post-m3"
  },
  {
   "at_ms": 1010000,
   "node": "M1",
   "command": "send_layerx 7 1163906905 post-m4"
  },
  {
   "_c": "and one reverse post-re-home (a re-homed mobile sends cross-layer)",
   "at_ms": 1060000,
   "node": "M4",
   "command": "send_layerx 4 655814605 post-re-m4"
  },
  {
   "_c": "PHASE F — after M5's voluntary re-home (~950k): a static sender reaches M5 by hash; must ride S3's redirect -> SX (green today via the stale proxy; must SURVIVE the handoff)",
   "at_ms": 1150000,
   "node": "S1",
   "command": "send_hash 44070031 hello-m5-moved"
  }
