  {
   "_c": "Team-X: X1 -> X3 by hash (2-hop, X3 unheard) -> forces a TEAM-X-scoped H flood heard by co-located Team-Y",
   "at_ms": 300000,
   "node": "X1",
   "command": "send_hash aaaa0003 hop_x"
  },
  {
   "_c": "Team-X: X1 -> X3 by hash (2-hop, X3 unheard) -> forces a TEAM-X-scoped H flood heard by co-located Team-Y",
   "at_ms": 360000,
   "node": "X1",
   "command": "send_hash aaaa0003 hop_x"
  },
  {
