{
 "_name": "s23_mobile_team_multihop",
 "_desc": "TEAM-plane MULTI-HOP routing parity with the static net (s19 analogue). 6 off-grid team mobiles in a redundant 3-hop chain TeamA-{TeamL,TeamL2}-{TeamR,TeamR2}-TeamB with TWO disjoint A<->B paths and NO A<->B direct link => every A->B team DM MUST relay >=2 hops through the _rt_team plane. Mirrors s19 (the static 3-hop chain) node-for-node, but on the TEAM plane, to PROVE team routing works the same way as static routing at real hop counts. Addressed by team-local-id (send <id> -t) = the PRIMARY routing mechanism (mirrors s19's send-by-id; hash is a neighbour-only secondary), routed multi-hop via _rt_team beacon-DV. team-DAD ids (seed 23, deterministic): TeamA=115 TeamL=118 TeamL2=17 TeamR=196 TeamR2=227 TeamB=254.",
 "simulation": {
  "duration_ms": 600000,
  "step_ms": 1,
  "warmup_ms": 0,
  "beacon_period_ms": 20000,
  "seed": 23,
  "node_startup_jitter_ms": 0,
  "radio": { "sf": 8, "bw": 62.5, "cr": 5, "max_packet_bytes": 255, "snr_coherence_ms": 0, "duty_cycle": 0.1 }
 },
 "commands": [
  { "_c": "TEAM 3-hop DM A -> B by team-local-id 254 (primary): no direct A-B link, must relay A->{L|L2}->{R|R2}->B via _rt_team DV", "at_ms": 300000, "node": "TeamA", "command": "send 254 -t hop_test" },
  { "at_ms": 360000, "node": "TeamA", "command": "send 254 -t hop_test" },
  { "at_ms": 420000, "node": "TeamA", "command": "send 254 -t hop_test" },
  { "_c": "reverse 3-hop DM B -> A by team-local-id 115 (parity: bidirectional multi-hop)", "at_ms": 480000, "node": "TeamB", "command": "send 115 -t hop_back" }
 ],
 "expect": [
  { "_c": "team-DAD on all 6 members", "type": "script_emit_contains", "node": "TeamA", "emit_type": "team_dad_adopted", "value": "id" },
  { "type": "script_emit_contains", "node": "TeamB", "emit_type": "team_dad_adopted", "value": "id" },
  { "type": "script_emit_contains", "node": "TeamL", "emit_type": "team_dad_adopted", "value": "id" },
  { "type": "script_emit_contains", "node": "TeamR", "emit_type": "team_dad_adopted", "value": "id" },
  { "_c": "★ MULTI-HOP: B receives A's team DM over >=2 relay hops (proves team routing == static routing)", "type": "script_emit_contains", "node": "TeamB", "emit_type": "push", "value": "hop_test" },
  { "_c": "★ reverse multi-hop: A receives B's team DM", "type": "script_emit_contains", "node": "TeamA", "emit_type": "push", "value": "hop_back" }
 ],
