{
 "_name": "s22_mobile_team",
 "_desc": "Comprehensive mobile+team plane test. Static net {S1(home),S2} + off-grid team {TeamA,TeamB,TeamC} (real crypto identities via per-node seeds) + a home-registered mobile {M1}, co-located so statics HEAR the team beacons. Checks: (#1) team beacons DON'T leak into a static id_bind, (#2) plaintext team DM, (#3) ENCRYPTED team DM via team-scoped WANT_PUBKEY (reqpubkey -> peer_key_cached -> send_hashx), (#4) static->registered-mobile via home last-mile, (#5) registered-mobile->static with e2e reverse-ack, plus team-DAD, team channel + containment, team-DM containment, mobile-id non-leak. Team key_hash32 are seed-derived (LE(ed_pub[:4])): TeamA a1*32=0x2215F68F, TeamB b2*32=0x8B94BBD1, TeamC c3*32=0x38E8B9F4. Pairs with the s18 byte-identity tripwire.",
 "simulation": {
  "duration_ms": 300000,
  "step_ms": 1,
  "warmup_ms": 0,
  "beacon_period_ms": 20000,
  "seed": 22,
  "node_startup_jitter_ms": 0,
  "radio": { "sf": 8, "bw": 62.5, "cr": 5, "max_packet_bytes": 255, "snr_coherence_ms": 0, "duty_cycle": 0.01 },
  "path_loss": {
   "model": "log_distance", "mobile_only": true, "alpha": 3.0, "sigma_db": 1.0,
   "ref_distance_m": 1.0, "ref_loss_db": 40.0, "noise_floor_db": -120.0, "tx_power_dbm": 14.0,
   "node_tx_offset_sigma_db": 1.0, "node_rx_offset_sigma_db": 1.0, "asymmetry_coherence_ms": 60000
  }
 },
 "commands": [
  { "_c": "#3 step1: TeamA fetches TeamC's E2E pubkey on-air (team-scoped WANT_PUBKEY)", "at_ms": 100000, "node": "TeamA", "command": "reqpubkey 38e8b9f4" },
  { "_c": "team channel broadcast", "at_ms": 118000, "node": "TeamA", "command": "send_channel 5 team_bcast_hello" },
  { "at_ms": 138000, "node": "TeamA", "command": "send_channel 5 team_bcast_hello" },
  { "_c": "#2 plaintext team DM (by teammate hash)", "at_ms": 150000, "node": "TeamA", "command": "send_hash 38e8b9f4 team_dm_ping" },
  { "at_ms": 170000, "node": "TeamA", "command": "send_hash 38e8b9f4 team_dm_ping" },
  { "_c": "#3 step2: TeamA sends an ENCRYPTED (sealed) team DM to TeamC", "at_ms": 162000, "node": "TeamA", "command": "send_hashx 38e8b9f4 crypted_team_msg" },
  { "at_ms": 186000, "node": "TeamA", "command": "send_hashx 38e8b9f4 crypted_team_msg" },
  { "_c": "#4 static S2 -> registered mobile M1 (by hash; S1 home last-miles)", "at_ms": 205000, "node": "S2", "command": "send_hash 11110060 static_to_mobile" },
  { "at_ms": 228000, "node": "S2", "command": "send_hash 11110060 static_to_mobile" },
  { "_c": "#5 registered mobile M1 -> static S2 with e2e-ACK (reverse leg)", "at_ms": 248000, "node": "M1", "command": "send_e2e S2 mobile_to_static" },
  { "at_ms": 272000, "node": "M1", "command": "send_e2e S2 mobile_to_static" }
 ],
 "expect": [
  { "_c": "team-DAD", "type": "script_emit_contains", "node": "TeamA", "emit_type": "team_dad_adopted", "value": "id" },
  { "type": "script_emit_contains", "node": "TeamB", "emit_type": "team_dad_adopted", "value": "id" },
  { "type": "script_emit_contains", "node": "TeamC", "emit_type": "team_dad_adopted", "value": "id" },

  { "_c": "team CHANNEL received by both teammates", "type": "script_emit_contains", "node": "TeamB", "emit_type": "channel_msg_received", "value": "\"channel_id\":5" },
  { "type": "script_emit_contains", "node": "TeamC", "emit_type": "channel_msg_received", "value": "\"channel_id\":5" },
  { "_c": "CONTAINMENT (channel): static ingests 0 team-channel messages", "type": "event_count", "event_type": "script_emit", "emit_type": "channel_msg_received", "node": "S1", "count": 0 },

  { "_c": "#2 plaintext team DM delivers", "type": "script_emit_contains", "node": "TeamC", "emit_type": "push", "value": "team_dm_ping" },
  { "_c": "CONTAINMENT (DM): the static never delivers the team DM", "type": "script_emit_not_contains", "node": "S1", "emit_type": "push", "value": "team_dm_ping" },

  { "_c": "#3 ENCRYPTED team DM: TeamA fetched TeamC's pubkey (team-scoped WANT_PUBKEY worked) ...", "type": "script_emit_contains", "node": "TeamA", "emit_type": "peer_key_cached", "value": "hash" },
  { "_c": "... and the sealed DM decrypts + delivers at TeamC", "type": "script_emit_contains", "node": "TeamC", "emit_type": "push", "value": "crypted_team_msg" },

  { "_c": "#1 beacon NON-LEAK: S1 never id_binds a team member's (seed-derived) key", "type": "script_emit_not_contains", "node": "S1", "emit_type": "id_bind_set", "value": "571864719" },
  { "type": "script_emit_not_contains", "node": "S1", "emit_type": "id_bind_set", "value": "2341780433" },
  { "type": "script_emit_not_contains", "node": "S1", "emit_type": "id_bind_set", "value": "954776052" },

  { "_c": "#4 static -> registered mobile via home last-mile", "type": "script_emit_contains", "node": "M1", "emit_type": "push", "value": "static_to_mobile" },
  { "type": "script_emit_contains", "node": "S1", "emit_type": "mobile_lastmile_fwd", "value": "local" },
  { "_c": "#6.2 mobile-id NON-LEAK: the static sender never id_binds M1's local id (key 0x11110060=286326880)", "type": "script_emit_not_contains", "node": "S2", "emit_type": "id_bind_set", "value": "286326880" },

  { "_c": "#5 registered mobile -> static with e2e reverse-ack", "type": "script_emit_contains", "node": "S2", "emit_type": "push", "value": "mobile_to_static" },
  { "type": "script_emit_contains", "node": "M1", "emit_type": "push", "value": "send_e2e_acked" }
 ],
 "nodes": [
  { "name": "S1", "script": "scenarios/dv_dual_sf.lua", "lat": 47.60000, "lon": -122.30000, "start_at_ms": 1000, "node_id": 17, "key_hash32": "0x11110017",
